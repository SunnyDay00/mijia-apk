# Copy this file to .env and fill in your plug details.

# Xiaomi Smart Plug 3 LAN address.
PLUG_IP=192.168.1.100

# 32-character miIO token for the plug.
PLUG_TOKEN=00000000000000000000000000000000

# Optional shared secret for phone requests. Leave empty only on a trusted LAN.
API_KEY=change-this-key

# HTTP server bind address and port.
HOST=0.0.0.0
PORT=8787

# Xiaomi Smart Plug 3 / cuco.plug.v3 switch property defaults.
PLUG_SWITCH_SIID=2
PLUG_SWITCH_PIID=1
PLUG_SWITCH_DID=switch:on

# Optional status properties. Disable by setting empty values.
PLUG_POWER_SIID=11
PLUG_POWER_PIID=1
PLUG_POWER_DID=electric-power
PLUG_CONSUMPTION_SIID=11
PLUG_CONSUMPTION_PIID=2
PLUG_CONSUMPTION_DID=power-consumption
